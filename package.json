{
  "name": "campaign_message_gui",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "node dist/main.js",
    "clean": "rm -rf dist backend/dist frontend/dist",
    "dir": "mkdir dist ",
    "build-backend": "cd backend && nest build && cd ..",
    "build-frontend": "cd frontend && run-p type-check \"build-only {@}\" --  && cd ..",
    "copy-build-backend": "cp -r backend/README.md backend/dist/* ./dist",
    "copy-build-frontend": "cp -r frontend/dist ./dist/public",
    "format": "prettier --write \"backend/src/**/*.ts\" \"backend/test/**/*.ts\" && prettier --write frontend/src/",
    "build": "npm run clean && npm run dir && npm run build-backend && npm run copy-build-backend && npm run build-frontend && npm run copy-build-frontend",
    "tar": "tar -czvf campaign_message_gui.tar.gz dist node_modules package.json start.cmd start.sh README.md .env",
    "package": "rm -rf campaign_message_gui.tar.gz && npm run build && npm run tar"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.3",
    "@nestjs/core": "^10.3.3",
    "@nestjs/mapped-types": "^2.0.5",
    "@nestjs/platform-express": "^10.3.3",
    "@nestjs/platform-socket.io": "^10.3.6",
    "@nestjs/serve-static": "^4.0.1",
    "@nestjs/websockets": "^10.3.6",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "csv-parser": "^3.0.0",
    "dotenv": "^16.4.5",
    "multer": "1.4.5-lts.1",
    "nestjs-paginate": "^8.6.2",
    "pg": "^8.20.0",
    "playwright": "^1.42.1",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "sqlite3": "^5.1.7",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "npm-run-all2": "^6.1.1",
    "prettier": "^3.0.3"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
